rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: sessions
    // Document ID: sessionId
    // Fields:
    //   - id: string (required)
    //   - mapId: string (required)
    //   - status: string (required, enum: ["waiting", "playing", "finished"])
    //   - players: map (required)
    //   - gameState: map (optional)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //   - createdBy: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "gaydev51@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 100 &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidSession(data) {
      return data.keys().hasAll(['id', 'mapId', 'status', 'players', 'createdBy']) &&
             data.id is string &&
             data.mapId is string &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.players is map &&
             data.createdBy is string &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSession(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isValidSession(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
